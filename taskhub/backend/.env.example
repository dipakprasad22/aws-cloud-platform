# Local development (.env) — copy to .env and adjust.
# In PRODUCTION on EC2, do NOT use a password here — set DB_SECRET_NAME instead
# so credentials are fetched from Secrets Manager at runtime.

PORT=3000
JWT_SECRET=change-me-to-a-long-random-string

# Local DB (dev)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taskhub

# Production (EC2): comment the DB_PASSWORD line above and set these instead:
# AWS_REGION=ap-south-1
# DB_SECRET_NAME=taskhub/db-credentials
# DB_HOST=<your-rds-endpoint>
# DB_NAME=taskhub
